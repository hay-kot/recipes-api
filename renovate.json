{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "pep621",
    "dockerfile",
    "mise"
  ],
  "extends": [
    "config:recommended"
  ],
  "ignoreDeps": [
    "python"
  ],
  "addLabels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "constraints": {
    "python": "3.14.6"
  },
  "packageRules": [
    {
      "matchManagers": [
        "pep621"
      ],
      "rangeStrategy": "pin"
    },
    {
      "matchDepNames": [
        "uv",
        "astral-sh/uv",
        "ghcr.io/astral-sh/uv"
      ],
      "groupName": "uv"
    }
  ]
}
